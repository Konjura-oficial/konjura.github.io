function animCounter(ts) {
    if (!animStart) animStart = ts;
    const p = Math.min((ts-animStart)/2000,1);
    counterEl.textContent = fmtCount(Math.floor(p*BASE_COUNT));
    if (p < 1) requestAnimationFrame(animCounter);
    else counterEl.textContent = fmtCount(BASE_COUNT);
}
