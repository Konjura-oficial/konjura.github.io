<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes">
    <title>KONJURA — ACTIVE TRANSMISSION</title>
    <link href="https://fonts.googleapis.com/css2?family=Courier+Prime:ital,wght@0,400;0,700;1,400&family=Orbitron:wght@400;700;900&family=VT323&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

    <style>
        :root {
            --green: #00ff41;
            --green-dim: rgba(0,255,65,0.4);
            --green-faint: rgba(0,255,65,0.07);
            --red: #ff2200;
            --bg: #000a00;
            --glow: 0 0 15px rgba(0,255,65,0.6);
        }

        *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
        @media (pointer:fine) { * { cursor: none !important; } }
        html { scroll-behavior: smooth; }
        
        body {
            background: var(--bg); color: var(--green);
            font-family: 'Courier Prime', monospace;
            overflow-x: hidden;
            animation: flicker 0.15s infinite;
        }

        @keyframes flicker { 0% { opacity: 0.98; } 50% { opacity: 1; } 100% { opacity: 0.99; } }

        body::before {
            content: " "; position: fixed; top: 0; left: 0; bottom: 0; right: 0;
            background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.1) 50%), 
                        linear-gradient(90deg, rgba(255, 0, 0, 0.02), rgba(0, 255, 0, 0.01), rgba(0, 0, 255, 0.02));
            z-index: 2000; background-size: 100% 3px, 3px 100%; pointer-events: none;
        }

        #rain-canvas { position:fixed; top:0; left:0; width:100%; height:100%; z-index:0; opacity:0.1; pointer-events:none; }
        
        .scanline-mobile {
            position: fixed; top: 0; left: 0; width: 100%; height: 8px;
            background: rgba(0, 255, 65, 0.1); z-index: 1001; pointer-events: none;
            animation: scanMove 10s linear infinite;
        }
        @keyframes scanMove { 0% { top: -10%; } 100% { top: 110%; } }

        #cursor-outer { position:fixed; pointer-events:none; z-index:10000; width:30px; height:30px; border:1px solid var(--green); transform:translate(-50%,-50%); transition: 0.08s; }
        #cursor-dot { position:fixed; pointer-events:none; z-index:10001; width:5px; height:5px; background:var(--green); transform:translate(-50%,-50%); box-shadow:var(--glow); }

        /* ======= BOOT SCREEN ======= */
        #boot-screen {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: #000; z-index: 99999; display: flex; flex-direction: column;
            justify-content: flex-start; align-items: flex-start; padding: 50px 60px;
            font-family: 'VT323'; font-size: 1.05rem; color: var(--green);
            overflow: hidden;
        }
        #boot-screen.fade-out { animation: bootFade 0.8s ease forwards; }
        @keyframes bootFade { 0% { opacity: 1; } 100% { opacity: 0; pointer-events: none; } }
        .boot-line { line-height: 1.7; white-space: pre; }
        .boot-bar-total {
            display: inline-block; border: 1px solid var(--green-dim);
            height: 14px; width: 220px; vertical-align: middle; margin-right: 8px;
            position: relative; overflow: hidden;
        }
        .boot-bar-fill { display: block; background: var(--green); height: 100%; width: 0; }

        /* ======= NAV ======= */
        .nav-wrapper {
            position:fixed; top:0; left:0; width:100%; z-index:1000;
            padding:0 20px; height:60px; display:flex; align-items:center;
            background:rgba(0,10,0,0.95); border-bottom:1px solid var(--green-dim);
            justify-content: space-between; gap: 10px;
        }
        .nav-logo { font-family:'Orbitron'; font-weight:900; font-size:1.4rem; color:var(--green); text-decoration:none; flex-shrink:0; }
        .nav-logo::after { content: '_'; margin-left: 5px; animation: blink 0.8s infinite; }
        @keyframes blink { 0% { opacity: 0; } 50% { opacity: 1; } }

        .ticker-container { flex: 1; margin: 0 20px; overflow: hidden; white-space: nowrap; font-family: 'VT323'; font-size: 1.2rem; opacity: 0.6; min-width: 0; }
        .ticker-text { display: inline-block; animation: marquee 25s linear infinite; }
        @keyframes marquee { 0% { transform: translateX(100%); } 100% { transform: translateX(-100%); } }

        .nav-links { display:flex; list-style:none; flex-shrink:0; }
        .nav-links a { font-size:0.7rem; color:var(--green); text-decoration:none; font-weight: bold; margin-left: 10px; }

        #clearance-badge {
            font-family: 'VT323'; font-size: 0.8rem; flex-shrink:0;
            border: 1px solid var(--green-dim); padding: 2px 7px;
            color: var(--green); white-space: nowrap; transition: 0.3s;
        }
        #clearance-badge.level-up { animation: levelFlash 0.5s ease; }
        @keyframes levelFlash { 0% { background: var(--green); color: #000; } 100% { background: transparent; } }

        section { padding:60px 20px; max-width:900px; margin:0 auto; position:relative; z-index:2; }

        /* ======= HERO ======= */
        #hero { height: 75vh; display:flex; flex-direction:column; align-items:center; justify-content:center; text-align:center; }
        .hero-title { 
            font-family:'Orbitron'; font-weight:900; font-size:clamp(3rem, 12vw, 8rem); 
            color:var(--green); text-shadow:var(--glow); letter-spacing:10px; transition: 0.1s;
        }
        .hero-title:hover { animation: bigGlitch 0.3s steps(1) infinite; cursor:crosshair; }
        @keyframes bigGlitch {
            0%  { text-shadow:4px 0 var(--red), -4px 0 #0ff; transform: skew(2deg); }
            50% { text-shadow:-4px 0 var(--red), 4px 0 #0ff; transform: translate(3px, -3px); }
        }
        #daily-msg { font-family:'VT323'; font-size:0.9rem; opacity:0.45; margin-top:8px; letter-spacing:2px; }

        /* ======= RADAR ======= */
        #radar-section {
            text-align: center; padding: 0 20px 60px;
            max-width: 900px; margin: 0 auto; position: relative; z-index: 2;
        }
        #radar-title { font-family:'VT323'; font-size:1rem; opacity:0.7; margin-bottom:16px; letter-spacing:4px; }
        #radar-canvas { display:block; margin:0 auto; border:1px solid var(--green-dim); box-shadow:0 0 20px rgba(0,255,65,0.1); }
        .signal-stats { display:flex; justify-content:center; gap:50px; margin-top:20px; font-family:'VT323'; }
        .stat-item { text-align:center; }
        .stat-value { font-size:1.8rem; color:#fff; display:block; }
        .stat-label { opacity:0.5; font-size:0.85rem; }

        /* ======= COUNTER ======= */
        #transmission-counter {
            text-align:center; padding:20px 20px 60px;
            max-width:900px; margin:0 auto; z-index:2; position:relative;
        }
        .counter-value { font-family:'Orbitron'; font-size:clamp(2rem,6vw,3.5rem); color:#fff; text-shadow:var(--glow); letter-spacing:3px; }
        .counter-label { font-family:'VT323'; font-size:1rem; opacity:0.5; margin-top:5px; letter-spacing:5px; }

        /* ======= DOSSIER ======= */
        #origin { background:rgba(0,255,65,0.02); border:1px solid var(--green-dim); padding:40px; margin-bottom:40px; position:relative; }
        .file-header { border-bottom:2px solid var(--green); margin-bottom:25px; padding-bottom:10px; display:flex; justify-content:space-between; align-items:flex-end; }
        .confidential-tag { background:var(--red); color:white; padding:5px 15px; font-weight:bold; position:absolute; top:-15px; right:20px; transform:rotate(2deg); box-shadow:0 0 10px var(--red); }
        .origin-text { line-height:1.8; font-size:0.95rem; text-align:justify; }
        .highlight { color:#fff; background:rgba(0,255,65,0.2); padding:0 4px; }
        .redacted { background:var(--green); color:var(--green); cursor:pointer; transition:0.3s; }
        .redacted.revealed { background:rgba(0,255,65,0.2); color:#fff; }

        /* ======= TRACKS ======= */
        .track { 
            display:grid; grid-template-columns:30px 60px 1fr auto; 
            align-items:center; gap:15px; padding:12px; border:1px solid rgba(0,255,65,0.1); 
            margin-bottom:10px; background:rgba(0,0,0,0.6); transition:0.3s; 
        }
        .track:hover { border-color:var(--green); background:rgba(0,255,65,0.05); }
        .waveform { display:flex; align-items:flex-end; gap:2px; height:15px; margin-top:5px; }
        .wave-bar { width:2px; background:var(--green); opacity:0.6; animation:bounce 0.5s ease-in-out infinite alternate; }
        @keyframes bounce { 0% { height:2px; } 100% { height:15px; } }
        .track-links { display:flex; gap:12px; margin-bottom:5px; justify-content:flex-end; font-size:1.1rem; }
        .track-links a { color:inherit; text-decoration:none; opacity:0.6; transition:0.2s; }
        .track-links a:hover { color:#fff; opacity:1; text-shadow:var(--glow); transform:scale(1.1); display:inline-block; }
        .btn-decode {
            font-family:'VT323'; font-size:0.85rem; color:var(--green);
            border:1px solid var(--green-dim); padding:3px 8px; cursor:pointer;
            background:transparent; display:block; width:100%; margin-top:5px;
        }
        .btn-decode:hover { background:var(--green); color:#000; }
        .info-panel {
            grid-column:1/-1; display:none; padding:12px;
            background:rgba(0,255,65,0.08); border-top:1px dashed var(--green);
            font-family:'VT323'; font-size:1rem; line-height:1.5; color:#fff;
            white-space: pre-line;
        }

        /* ======= TERMINAL ======= */
        .terminal-box { background:#000; border:1px solid var(--green); padding:20px; font-family:'VT323'; box-shadow:var(--glow); margin-bottom:40px; }
        .terminal-input { background:transparent; border:none; color:var(--green); font-family:'VT323'; font-size:1.2rem; width:80%; outline:none; }
        #term-output { margin-top:10px; color:#fff; min-height:60px; white-space:pre-line; }
        .term-hint { font-family:'VT323'; font-size:0.82rem; opacity:0.45; margin-bottom:8px; }

        /* ======= ACCESS CODE ======= */
        #access-section { max-width:900px; margin:0 auto; padding:0 20px 60px; position:relative; z-index:2; }
        .access-box { border:1px solid var(--red); padding:20px; background:rgba(255,34,0,0.03); font-family:'VT323'; position:relative; }
        .access-box::before {
            content:'⚠ CLASSIFIED ACCESS POINT ⚠'; position:absolute; top:-12px; left:20px;
            background:var(--bg); padding:0 10px; color:var(--red); font-size:0.9rem;
        }
        #access-input {
            background:transparent; border:none; border-bottom:1px solid var(--red);
            color:var(--red); font-family:'VT323'; font-size:1.4rem;
            width:100%; outline:none; margin-top:10px; letter-spacing:4px; text-transform:uppercase;
        }
        #access-input::placeholder { color:rgba(255,34,0,0.3); }
        #access-output {
            margin-top:15px; min-height:40px; font-size:1rem; color:#fff;
            white-space:pre-line; border-top:1px dashed rgba(255,34,0,0.3); padding-top:10px;
        }
        #access-output.success { color:var(--green); }
        #access-output.fail { color:var(--red); }

        /* ======= CONTACT / FOOTER ======= */
        .contact-icon { color:var(--green); transition:all 0.3s ease; display:inline-block; }
        .contact-icon:hover { transform:scale(1.2); color:#fff; text-shadow:var(--glow); }
        .footer-data { text-align:center; border-top:1px solid var(--green-dim); padding:40px 0; font-family:'VT323'; }

        /* ======= DOM GLITCH ======= */
        @keyframes domGlitch {
            0%   { transform:translateX(0); opacity:1; }
            15%  { transform:translateX(-4px); color:var(--red); }
            30%  { transform:translateX(4px); color:#0ff; }
            50%  { transform:translateX(-2px); color:var(--green); }
            100% { transform:translateX(0); opacity:1; }
        }
        .glitch-dom { animation:domGlitch 0.4s steps(1) forwards; }
    </style>
</head>
