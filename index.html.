<script>
/* ===== BOOT SCREEN ===== */
const bootSequence = [
    [0,    "KONJURA_OS v1.0.4 — INITIALIZING..."],
    [200,  " "],
    [400,  "BIOS CHECK.................. OK"],
    [600,  "MEMORY MODULE.............. 808 KB"],
    [800,  "TRANCE SIGNAL DETECTOR..... ONLINE"],
    [1000, "FASTRACKER ENGINE.......... LOADED"],
    [1200, "UPLIFTING FREQUENCY........ DETECTED"],
    [1400, " "],
    [1500, "LOADING KONJURA DATABASE..."],
    [1600, "BAR"],
    [2800, " "],
    [2900, "CLEARANCE LEVEL: 1 ASSIGNED"],
    [3100, "MADRID NODE: ACTIVE // STABLE TRANSMISSION"],
    [3300, " "],
    [3400, ">> ACCESS GRANTED. WELCOME, AGENT."],
];

const bootContainer = document.getElementById('boot-lines');

bootSequence.forEach(([delay, content]) => {
    setTimeout(() => {
        if (content === "BAR") {
            const wrap = document.createElement('div');
            wrap.className = 'boot-line';
            wrap.innerHTML = `LOADING: <span class="boot-bar-total"><span class="boot-bar-fill" id="bfill"></span></span><span id="bpct">0%</span>`;
            bootContainer.appendChild(wrap);
            let p = 0;
            const iv = setInterval(() => {
                p = Math.min(p + Math.random() * 7 + 2, 100);
                const f = document.getElementById('bfill');
                const b = document.getElementById('bpct');
                if (f) f.style.width = (p * 2.2) + 'px';
                if (b) b.textContent = Math.floor(p) + '%';
                if (p >= 100) clearInterval(iv);
            }, 55);
        } else {
            const div = document.createElement('div');
            div.className = 'boot-line';
            div.textContent = content;
            bootContainer.appendChild(div);
        }
    }, delay);
});

setTimeout(() => {
    const boot = document.getElementById('boot-screen');
    boot.classList.add('fade-out');
    setTimeout(() => { boot.style.display = 'none'; }, 800);
    startClearanceTimer();
    startDomGlitch();
}, 4100);


/* ===== MATRIX RAIN ===== */
const canvas = document.getElementById('rain-canvas');
const ctx = canvas.getContext('2d');
function resRain() { canvas.width = window.innerWidth; canvas.height = window.innerHeight; }
window.addEventListener('resize', resRain); resRain();
const drops = Array(Math.floor(canvas.width / 20)).fill(1);
setInterval(() => {
    ctx.fillStyle = 'rgba(0,10,0,0.08)'; ctx.fillRect(0,0,canvas.width,canvas.height);
    ctx.fillStyle = '#0f0'; ctx.font = '15px monospace';
    drops.forEach((y,i) => {
        ctx.fillText(Math.random()>0.5?"0":"1", i*20, y*20);
        if (y*20 > canvas.height && Math.random() > 0.98) drops[i] = 0;
        drops[i]++;
    });
}, 60);


/* ===== CURSOR ===== */
document.addEventListener('mousemove', e => {
    document.getElementById('cursor-outer').style.left = e.clientX + 'px';
    document.getElementById('cursor-outer').style.top  = e.clientY + 'px';
    document.getElementById('cursor-dot').style.left   = e.clientX + 'px';
    document.getElementById('cursor-dot').style.top    = e.clientY + 'px';
    incrementClearance(0.05);
});


/* ===== RADAR ===== */
const rc = document.getElementById('radar-canvas');
const rctx = rc.getContext('2d');
const RCX = rc.width / 2, RCY = rc.height / 2, RR = 125;
let radarAngle = 0;
const nodes = Array.from({length: 14}, () => ({
    a: Math.random()*Math.PI*2, d: 25+Math.random()*95,
    life: Math.floor(Math.random()*80), maxLife: 60+Math.random()*80
}));
function drawRadar() {
    rctx.clearRect(0,0,rc.width,rc.height);
    rctx.fillStyle='#000a00'; rctx.fillRect(0,0,rc.width,rc.height);
    [30,60,90,RR].forEach(r => {
        rctx.beginPath(); rctx.arc(RCX,RCY,r,0,Math.PI*2);
        rctx.strokeStyle='rgba(0,255,65,0.12)'; rctx.lineWidth=1; rctx.stroke();
    });
    rctx.strokeStyle='rgba(0,255,65,0.1)'; rctx.lineWidth=1;
    rctx.beginPath(); rctx.moveTo(RCX,RCY-RR); rctx.lineTo(RCX,RCY+RR); rctx.stroke();
    rctx.beginPath(); rctx.moveTo(RCX-RR,RCY); rctx.lineTo(RCX+RR,RCY); rctx.stroke();

    rctx.save(); rctx.translate(RCX,RCY); rctx.rotate(radarAngle);
    const grad = rctx.createLinearGradient(0,0,RR,0);
    grad.addColorStop(0,'rgba(0,255,65,0.55)'); grad.addColorStop(1,'rgba(0,255,65,0)');
    rctx.beginPath(); rctx.moveTo(0,0); rctx.arc(0,0,RR,-0.45,0.45); rctx.closePath();
    rctx.fillStyle=grad; rctx.fill(); rctx.restore();

    nodes.forEach(n => {
        n.life++;
        if (n.life > n.maxLife) { n.life=0; n.maxLife=60+Math.random()*80; n.a=Math.random()*Math.PI*2; n.d=25+Math.random()*95; }
        const alpha = 1 - n.life/n.maxLife;
        const nx = RCX + Math.cos(n.a)*n.d, ny = RCY + Math.sin(n.a)*n.d;
        rctx.beginPath(); rctx.arc(nx,ny,2.5,0,Math.PI*2);
        rctx.fillStyle=`rgba(0,255,65,${alpha})`; rctx.fill();
        if (n.life < 18) {
            rctx.beginPath(); rctx.arc(nx,ny,(n.life/18)*10,0,Math.PI*2);
            rctx.strokeStyle=`rgba(0,255,65,${0.4-n.life*0.022})`; rctx.lineWidth=1; rctx.stroke();
        }
    });
    rctx.beginPath(); rctx.arc(RCX,RCY,4,0,Math.PI*2);
    rctx.fillStyle='#fff'; rctx.fill();
    rctx.fillStyle='rgba(0,255,65,0.7)'; rctx.font='10px VT323,monospace';
    rctx.fillText('MAD',RCX+6,RCY-6);
    radarAngle += 0.03;
    requestAnimationFrame(drawRadar);
}
